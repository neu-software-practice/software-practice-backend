# Copy to .env and adjust. NEVER commit real secrets (SPEC §7.2).

# Application
APP_ENV=development
HTTP_PORT=8080
LOG_LEVEL=info
CORS_ORIGINS=*

# Database (GORM/MySQL DSN). parseTime=True is required for time.Time columns.
DATABASE_DSN=his:hispw@tcp(127.0.0.1:3306)/his?charset=utf8mb4&parseTime=True&loc=Local

# Test database DSN (required for integration tests). The database name (mysql)
# is used only for bootstrap — each test creates an isolated temporary database.
# Start the test MySQL container with: make test-mysql-up
TEST_DATABASE_DSN=root:rootpw@tcp(127.0.0.1:3307)/mysql?charset=utf8mb4&parseTime=True&loc=Local

# Auth
JWT_SECRET=change-me-in-production-please-use-a-long-random-value
JWT_TTL_HOURS=12

# Seed: password applied to every seeded demo account.
SEED_DEFAULT_PASSWORD=Passw0rd!
