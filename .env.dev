# =========================
# NEUHIS Agent 后端配置 - Dev 环境
# 由 dev-cd workflow 复制为 .env
# 密钥通过 GitHub Secrets 注入
# =========================

# --- 服务 ---
SERVER_ADDR=:8080
SERVER_MODE=debug

# --- 数据库 ---
DATABASE_DSN=root:password@tcp(mysql:3306)/neuhis_dev?charset=utf8mb4&parseTime=True&loc=Local

# --- JWT ---
JWT_SECRET=change-me-to-a-random-string-at-least-32-bytes-long
# 占位符 — workflow 会通过 DEV_JWT_SECRET secret 替换

# --- CORS ---
CORS_ALLOWED_ORIGINS=*
# debug 模式下允许通配符

# --- medAgent 集成 ---
MEDAGENT_MODE=http
MEDAGENT_BASE_URL=http://medagent:8080
MEDAGENT_API_KEY=sk-placeholder-dev-key
# 占位符 — workflow 会通过 DEV_MEDAGENT_API_KEY secret 替换
MEDAGENT_PROVIDER=deepseek
MEDAGENT_MODEL=deepseek-chat

# --- 日志 ---
LOG_LEVEL=debug
