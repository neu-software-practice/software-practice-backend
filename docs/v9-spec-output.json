{
  "file": "docs/rest-api-patch-v9.md",
  "baseUrl": "/api",
  "auth": {
    "mechanism": "Token-based (patient identity established via POST /patients/verify, subsequent requests carry patientId/sessionId as identifiers; token bearer mechanism determined by backend auth gateway, transparently passed by frontend transport layer)",
    "headerName": "Authorization (via RequestOptions.headers, transparently passed by transport layer)",
    "tokenTypes": ["bearer"],
    "refreshEndpoint": "Not specified (frontend contract does not define auth refresh)"
  },
  "endpoints": [
    {
      "method": "POST",
      "path": "/visits/:sessionId/suspend",
      "summary": "Suspend a visit session when idle timeout triggers (lastActivityAt exceeds idle threshold). Non-terminal state — does not write endedAt or terminalReason, only sets status to 'suspended' and clears activeCardId.",
      "pathParams": [
        {
          "name": "sessionId",
          "type": "SessionId (z.string().trim().min(1))",
          "description": "Session ID of the visit to suspend"
        }
      ],
      "requestBody": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "SessionId (z.string().trim().min(1))",
            "required": true,
            "description": "The session ID to suspend"
          }
        }
      },
      "responseBody": {
        "type": "object",
        "properties": {
          "session": {
            "type": "VisitSession",
            "required": true,
            "description": "Updated visit session with status=suspended"
          },
          "timelineItem": {
            "type": "TimelineItem",
            "required": true,
            "description": "System_event type TimelineItem with eventType=session_suspended"
          }
        }
      },
      "statusCodes": [200, 404, 422],
      "errorCodes": ["SESSION_NOT_FOUND", "INVALID_STATE"],
      "queryParams": [],
      "headers": [],
      "authRequired": true,
      "isSSE": false,
      "version": "v9"
    }
  ],
